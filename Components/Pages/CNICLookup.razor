@page "/cniclookup"
@using SMS.Models
@using SMS.Services
@inject IDocumentProcessingService DocumentService
@inject IMemberService MemberService
@rendermode InteractiveServer

<div class="min-vh-100 bg-gradient">
    <div class="container py-5">
        <div class="row mb-5">
            <div class="col-12">
                <div class="header-section text-center mb-5">
                    <h1 class="display-4 fw-bold text-primary mb-3">
                        <i class="fas fa-search"></i> CNIC Member Lookup
                    </h1>
                    <p class="lead text-muted">Upload your documents to extract CNIC and find member records</p>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-8 mx-auto">
                <!-- Upload Section -->
                <div class="card shadow-lg border-0 mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0"><i class="fas fa-upload"></i> Upload Document</h5>
                    </div>
                    <div class="card-body p-5">
                        <!-- Hidden real input -->
                        <InputFile id="fileInput"
                                   OnChange="HandleFileSelected"
                                   accept=".pdf,.jpg,.jpeg,.png"
                                   style="display: none;" />

                        <!-- Clickable label acts as the trigger -->
                        <label for="fileInput" class="upload-zone w-100 d-block text-center"
                               style="cursor: pointer; border: 2px dashed #0d6efd; border-radius: 12px; padding: 40px; background: #f8f9ff;">
                            <i class="fas fa-cloud-upload-alt display-1 text-primary mb-3 d-block"></i>
                            <p class="mb-2 fw-bold">Click to upload your documents</p>
                            <small class="text-muted d-block">Supported: PDF, JPEG, PNG (Max 10MB)</small>
                        </label>

                        @if (!string.IsNullOrEmpty(FileName))
                        {
                            <div class="alert alert-info mt-3 mb-0">
                                <i class="fas fa-file"></i> <strong>Selected:</strong> @FileName
                                @if (IsProcessing)
                                {
                                    <span class="spinner-border spinner-border-sm ms-2"></span> <span>Processing...</span>
                                }
                            </div>
                        }
                    </div>
                </div>

                <!-- Extracted CNICs Section -->
                @if (ExtractedCNICs.Any())
                {
                    <div class="card shadow-lg border-0 mb-4">
                        <div class="card-header bg-success text-white">
                            <h5 class="mb-0"><i class="fas fa-id-card"></i> Extracted CNICs</h5>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                @foreach (var cnic in ExtractedCNICs)
                                {
                                    <div class="col-md-6 mb-2">
                                        <div class="cnic-badge">
                                            <span class="badge bg-info">@cnic</span>
                                            <button class="btn btn-sm btn-outline-danger ms-2" @onclick="() => RemoveCNIC(cnic)">
                                                <i class="fas fa-times"></i>
                                            </button>
                                        </div>
                                    </div>
                                }
                            </div>
                            <button class="btn btn-primary btn-lg w-100 mt-3" @onclick="SearchMembers" disabled="@IsSearching">
                                <i class="fas fa-search"></i> Search Members
                                @if (IsSearching)
                                {
                                    <span class="spinner-border spinner-border-sm ms-2"></span>
                                }
                            </button>
                        </div>
                    </div>
                }

                <!-- Error Messages -->
                @if (!string.IsNullOrEmpty(ErrorMessage))
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="fas fa-exclamation-circle"></i> <strong>Error:</strong> @ErrorMessage
                        <button type="button" class="btn-close" @onclick="() => ClearError()"></button>
                    </div>
                }

                <!-- Success Messages -->
                @if (!string.IsNullOrEmpty(SuccessMessage))
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="fas fa-check-circle"></i> @SuccessMessage
                        <button type="button" class="btn-close" @onclick="() => ClearSuccess()"></button>
                    </div>
                }

                <!-- Results Section -->
                @if (MemberResults.Any())
                {
                    <div class="card shadow-lg border-0">
                        <div class="card-header bg-dark text-white">
                            <h5 class="mb-0"><i class="fas fa-users"></i> Member Records (@MemberResults.Count)</h5>
                        </div>
                        <div class="card-body p-0">
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Full Name</th>
                                            <th>CNIC</th>
                                            <th>Membership No</th>
                                            <th>Plot No</th>
                                            <th>Cell No</th>
                                            <th>Address</th>
                                            <th>Details</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var member in MemberResults)
                                        {
                                            <tr>
                                                <td class="fw-bold">@member.FullName</td>
                                                <td><code>@member.CNIC</code></td>
                                                <td>@member.MeshipNo</td>
                                                <td>@member.PFlotNo @member.PFlotNo2</td>
                                                <td>@member.CellNo</td>
                                                <td class="text-truncate" title="@member.Address1">@member.Address1</td>
                                                <td>
                                                    <button class="btn btn-sm btn-info" @onclick="() => ExpandDetails(member)">
                                                        <i class="fas fa-expand"></i> View
                                                    </button>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                }
                else if (HasSearched && !MemberResults.Any() && string.IsNullOrEmpty(ErrorMessage))
                {
                    <div class="alert alert-warning">
                        <i class="fas fa-info-circle"></i> No member records found for the extracted CNICs.
                    </div>
                }
            </div>
        </div>

        <!-- Details Modal -->
        @if (SelectedMember != null)
        {
            <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);">
                <div class="modal-dialog modal-lg">
                    <div class="modal-content">
                        <div class="modal-header bg-info text-white">
                            <h5 class="modal-title">Member Details</h5>
                            <button type="button" class="btn-close btn-close-white" @onclick="() => SelectedMember = null"></button>
                        </div>
                        <div class="modal-body">
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <p><strong>Full Name:</strong> @SelectedMember.FullName</p>
                                    <p><strong>CNIC:</strong> <code>@SelectedMember.CNIC</code></p>
                                    <p><strong>Membership No:</strong> @SelectedMember.MeshipNo</p>
                                    <p><strong>Old Membership No:</strong> @SelectedMember.OldMNo</p>
                                </div>
                                <div class="col-md-6">
                                    <p><strong>Cell No:</strong> @SelectedMember.CellNo</p>
                                    <p><strong>Address:</strong> @SelectedMember.Address1</p>
                                    <p><strong>Project ID:</strong> <code>@SelectedMember.ProID</code></p>
                                    <p><strong>Book No:</strong> @SelectedMember.BookNo</p>
                                </div>
                            </div>
                            <hr />
                            <h6 class="fw-bold">Plot Information</h6>
                            <div class="row">
                                <div class="col-md-6">
                                    <p><strong>Plot No:</strong> @SelectedMember.PFlotNo</p>
                                    <p><strong>Plot No 2:</strong> @SelectedMember.PFlotNo2</p>
                                </div>
                                <div class="col-md-6">
                                    <p><strong>Street No:</strong> @SelectedMember.StNo</p>
                                    <p><strong>Plot Size:</strong> @SelectedMember.PlotSize</p>
                                </div>
                            </div>
                            <hr />
                            <p><strong>Allocation Date:</strong> @(SelectedMember.AlotTransEntryDate?.ToString("dd/MM/yyyy") ?? "N/A")</p>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" @onclick="() => SelectedMember = null">Close</button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private IDocumentProcessingService? documentService;
    private IMemberService? memberService;
    private List<string> ExtractedCNICs = new();
    private List<MemberLookupResult> MemberResults = new();
    private MemberLookupResult? SelectedMember;
    private string? FileName;
    private string? ErrorMessage;
    private string? SuccessMessage;
    private bool IsProcessing;
    private bool IsSearching;
    private bool HasSearched;

    protected override void OnInitialized()
    {
        documentService = DocumentService;
        memberService = MemberService;
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        try
        {
            ErrorMessage = null;
            IsProcessing = true;

            var file = e.File;

            if (file == null)
            {
                ErrorMessage = "Please select a file.";
                return;
            }

            FileName = file.Name;

            // Validate file size (max 10MB)
            if (file.Size > 10 * 1024 * 1024)
            {
                ErrorMessage = "File size exceeds 10MB limit.";
                FileName = null;
                return;
            }

            // Process file
            using (var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024))
            {
                var cnics = await documentService!.ExtractCNICsAsync(stream, file.Name);

                if (cnics.Any())
                {
                    ExtractedCNICs.AddRange(cnics);
                    SuccessMessage = $"Successfully extracted {cnics.Count} CNIC(s) from the document.";
                }
                else
                {
                    ErrorMessage = "No CNICs found in the document. Please check the file and try again.";
                }
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error processing file: {ex.Message}";
            FileName = null;
        }
        finally
        {
            IsProcessing = false;
        }
    }

    private void RemoveCNIC(string cnic)
    {
        ExtractedCNICs.Remove(cnic);
    }

    private async Task SearchMembers()
    {
        try
        {
            IsSearching = true;
            ErrorMessage = null;
            SuccessMessage = null;
            HasSearched = true;

            if (!ExtractedCNICs.Any())
            {
                ErrorMessage = "No CNICs to search. Please upload a document first.";
                return;
            }

            MemberResults = await memberService!.GetMembersByCNICsAsync(ExtractedCNICs);

            if (MemberResults.Any())
            {
                SuccessMessage = $"Found {MemberResults.Count} member record(s).";
            }
            else
            {
                ErrorMessage = "No member records found for the provided CNICs.";
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error searching members: {ex.Message}";
        }
        finally
        {
            IsSearching = false;
        }
    }

    private void ExpandDetails(MemberLookupResult member)
    {
        SelectedMember = member;
    }

    private void ClearError()
    {
        ErrorMessage = null;
    }

    private void ClearSuccess()
    {
        SuccessMessage = null;
    }
}


